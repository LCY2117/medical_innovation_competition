# Backend bind
LRA_HOST=0.0.0.0
LRA_PORT=8080
LRA_RELOAD=false

# API and behavior
LRA_API_PREFIX=/api
LRA_SOS_DURATION_SEC=10
LRA_DISPATCH_DELAY_SEC=3

# CORS (comma separated)
LRA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage and static hosting paths (relative to server(web)/)
LRA_DB_PATH=data/lifereflexarc.db
LRA_WEB_DIST_DIR=web/dist

# Web dev server (used by app.cli --with-web)
LRA_WEB_DEV_HOST=127.0.0.1
LRA_WEB_DEV_PORT=5173

# Optional AI dispatch provider
LRA_SILICONFLOW_API_KEY=
LRA_SILICONFLOW_MODEL=Qwen/Qwen2-7B-Instruct
LRA_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
LRA_SILICONFLOW_TIMEOUT_SEC=8

# Optional local model (prefer local when configured)
# Set to your local model service base URL (example provided by model_training)
# Example: http://localhost:8008/v1
LRA_LOCAL_MODEL_BASE_URL=
# Local model name (used in probes/requests)
LRA_LOCAL_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# Local model request timeout (seconds)
LRA_LOCAL_MODEL_TIMEOUT_SEC=30
# If true, try local model first, then remote API. If false, remote API first.
LRA_PREFER_LOCAL_MODEL=true
